# AWS
AWS_REGION=eu-west-2
AWS_ACCOUNT_ID=677276115158

# S3 buckets — created by Terraform
S3_INPUT_BUCKET=bcp-input
S3_RESULTS_BUCKET=bcp-results
S3_WORK_BUCKET=bcp-work
S3_REPORTS_BUCKET=bcp-reports

# Database — populated from Terraform output
DATABASE_URL=postgresql+asyncpg://biomarker:CHANGEME@localhost:5432/biomarker
DATABASE_SYNC_URL=postgresql+psycopg2://biomarker:CHANGEME@localhost:5432/biomarker

# GIAB reference — S3 paths to pre-staged reference files
GIAB_TRUTH_VCF=s3://bcp-results/reference/HG001_GRCh38_1_22_v4.2.1_benchmark.vcf.gz
GIAB_TRUTH_BED=s3://bcp-results/reference/HG001_GRCh38_1_22_v4.2.1_benchmark.bed
REFERENCE_GENOME=s3://bcp-results/reference/Homo_sapiens_assembly38.fasta

# API
API_HOST=0.0.0.0
API_PORT=8000

# Concordance thresholds
MIN_SNV_F1=0.98
MIN_INDEL_F1=0.95
MIN_SNV_PRECISION=0.98
MIN_SNV_RECALL=0.98

# Reproducibility thresholds
MIN_VAF_ICC=0.90
MAX_VAF_CV=0.15
